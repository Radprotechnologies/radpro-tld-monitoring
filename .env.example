DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres.PROJECT_REF:YOUR_DATABASE_PASSWORD@aws-1-ap-south-1.pooler.supabase.com:5432/postgres
PGSSLMODE=no-verify
PG_CONNECT_TIMEOUT_MS=15000
PG_BRIDGE_REQUEST_TIMEOUT_MS=30000
PG_BRIDGE_SPAWN_TIMEOUT_MS=40000
SESSION_SECRET=change_this_to_a_long_random_value
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
COOKIE_SECURE=false
DATA_DIR=./data
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25
ENABLE_DEMO_SEED=false
TWO_FACTOR_REQUIRED=false
AUTO_REMINDERS_ENABLED=false
REMINDER_INTERVAL_HOURS=24
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_URL=
BACKUP_KDF_ITERATIONS=150000

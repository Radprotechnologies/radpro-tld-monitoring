# Required in production. Generate with: openssl rand -hex 32
SESSION_SECRET=change_this_to_a_long_random_value

# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
# Set COOKIE_SECURE=true only when serving over HTTPS in production.
COOKIE_SECURE=false

# Persistent storage
DATA_DIR=./data
DB_FILE=./data/radpro_tld.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25

# Two-factor authentication
# Set true to require 2FA for every account. Individual users can also be marked 2FA-required in the RSO portal.
TWO_FACTOR_REQUIRED=false

# Automated reminder scheduler
AUTO_REMINDERS_ENABLED=false
REMINDER_INTERVAL_HOURS=24

# Email reminders / RSO notifications / 2FA via SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# WhatsApp reminders / RSO notifications / 2FA
# Option A: WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
# Option B: your own webhook that accepts JSON {to,message}
WHATSAPP_API_URL=

# Backup encryption KDF strength
BACKUP_KDF_ITERATIONS=150000

# Phase 1 cloud stabilization
# Keep absent/false in production to stop default demo hospital reseeding.
ENABLE_DEMO_SEED=false
# Render Starter persistent disk must be mounted at /app/data.
# Then set DATA_DIR=/app/data, DB_FILE=/app/data/radpro_tld.db, UPLOAD_DIR=/app/data/uploads.

# Phase 2 PostgreSQL migration variables
# Use these for migration scripts first. Native app PostgreSQL adapter is Phase 2B.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
PGSSLMODE=require
SQLITE_DB_FILE=/app/data/radpro_tld.db
PG_MIGRATION_BATCH_SIZE=200
